# Seerr environment configuration.
#
# API_KEY may be added here for REST API access. However the owner must be
# created manually before it can be used.
#
# Reference:
# * https://docs.seerr.dev/extending-seerr/database-config
# * https://docs.seerr.dev/using-seerr/users/owner

PORT=5055
HOST=
FORCE_IPV4_FIRST=false

DB_TYPE=postgres
DB_LOG_QUERIES=false
DB_HOST=localhost
DB_PORT=5432
DB_SOCKET_PATH=

DB_USER=seerr
DB_PASS=seerr
DB_NAME=seerr

DB_USE_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_FILE=
DB_SSL_KEY_FILE=
DB_SSL_CERT_FILE=